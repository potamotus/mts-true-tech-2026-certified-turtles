# MWS GPT = OpenAI-совместимый API для OpenWebUI (см. MWS-GPT.md)
# Скопируйте в .env (файл .env в git не коммитится)
MWS_API_KEY=

# Базовый URL без /v1 (в compose к нему добавляется /v1 для OpenWebUI)
# MWS_API_BASE=https://api.gpt.mws.ru

# Open WebUI (https://github.com/open-webui/open-webui)
OPEN_WEBUI_PORT=3000
# Секрет сессий; для продакшена смените на длинную случайную строку
WEBUI_SECRET_KEY=change-me
# Публичный URL интерфейса (для ссылок/OAuth при необходимости)
# WEBUI_URL=http://localhost:3000

# Заголовок в шапке (к имени Open WebUI добавится суффикс в стиле проекта)
# WEBUI_NAME=GPTHub
# Язык интерфейса по умолчанию
# DEFAULT_LOCALE=ru-RU

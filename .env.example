# MWS GPT = OpenAI-совместимый API для OpenWebUI (см. MWS-GPT.md)
# Скопируйте в .env (файл .env в git не коммитится)
MWS_API_KEY=

# Режим чата в Open WebUI (если одно подключение с base …/v1):
# в JSON тела chat/completions можно передать "use_agent": false — тогда запрос пойдёт в MWS без агента и тулов.
# Удобнее: второе подключение с OPENAI_API_BASE_URL=http://api:8000/v1/plain (см. README).

# Лимит HTTP-раундов chat/completions для CLI: mws-gpt agent --max-tool-rounds (по умолчанию из переменной)
# AGENT_MAX_TOOL_ROUNDS=10

# Базовый URL без /v1 (в compose к нему добавляется /v1 для OpenWebUI)
# MWS_API_BASE=https://api.gpt.mws.ru

# Таймаут чтения ответа MWS (секунды), 30–600; по умолчанию 120
# MWS_HTTP_TIMEOUT_SEC=120

# Open WebUI (https://github.com/open-webui/open-webui)
OPEN_WEBUI_PORT=3000
# Секрет сессий; для продакшена смените на длинную случайную строку
WEBUI_SECRET_KEY=change-me
# Публичный URL интерфейса (для ссылок/OAuth при необходимости)
# WEBUI_URL=http://localhost:3000

# Заголовок в шапке (к имени Open WebUI добавится суффикс в стиле проекта)
# WEBUI_NAME=GPTHub
# Язык интерфейса по умолчанию
# DEFAULT_LOCALE=ru-RU

# Загрузки для агента (POST /api/v1/uploads) и артефакты execute_python — подкаталоги GENERATED_FILES_DIR в compose.
# UPLOADS_DIR=/data/generated/uploads
# Лимит тела загрузки (байты)
# UPLOAD_MAX_BYTES=12582912

# Google Docs (опционально): в чате доступны тулы google_docs_read / google_docs_append.
# 1) Google Cloud → IAM → Service Account → ключ JSON.
# 2) GOOGLE_DOCS_CREDENTIALS_JSON — абсолютный путь к файлу на машине, где крутится API (в Docker — путь ВНУТРИ контейнера + volume).
# 3) В каждом документе: «Доступ» → добавить email из поля client_email в JSON → роль «Редактор».
# 4) Проверка: GET http://localhost:8000/health → capabilities.google_docs (готовность и email).
# GOOGLE_DOCS_CREDENTIALS_JSON=/path/to/sa.json
# Таймаут выполнения Python-тула (сек)
# PYTHON_TOOL_TIMEOUT_SEC=45

# MWS GPT = OpenAI-совместимый API для OpenWebUI (см. MWS-GPT.md)
# Скопируйте в .env (файл .env в git не коммитится)
MWS_API_KEY=

# Базовый URL без /v1 (в compose к нему добавляется /v1 для OpenWebUI)
# MWS_API_BASE=https://api.gpt.mws.ru

# Open WebUI (https://github.com/open-webui/open-webui)
OPEN_WEBUI_PORT=3000
# Секрет сессий; для продакшена смените на длинную случайную строку
WEBUI_SECRET_KEY=change-me
# Публичный URL интерфейса (для ссылок/OAuth при необходимости)
# WEBUI_URL=http://localhost:3000

# Заголовок в шапке (к имени Open WebUI добавится суффикс в стиле проекта)
# WEBUI_NAME=GPTHub
# Язык интерфейса по умолчанию
# DEFAULT_LOCALE=ru-RU

# ── GPTHub Memory System ──────────────────────────────────────
# API ключ для MWS GPT (используется Memory Extractor для извлечения фактов)
MWS_GPT_API_KEY=
# Модель для извлечения фактов (по умолчанию mws-gpt-alpha)
MEMORY_EXTRACTION_MODEL=mws-gpt-alpha
# Порог уверенности для сохранения фактов (0.0-1.0)
MEMORY_CONFIDENCE_THRESHOLD=0.7
# Размер батча для извлечения (кол-во сообщений перед вызовом LLM)
MEMORY_BATCH_SIZE=5
# Таймаут батча в секундах (макс время между extraction)
MEMORY_BATCH_TIMEOUT_SEC=300
# Максимум фактов для инжекции в контекст
MEMORY_MAX_MEMORIES=5
# Максимум токенов для memory context
MEMORY_MAX_TOKENS=2000
